# ==============================================================================
# StatementX Unified Environment Configurations Template
# Copy this file to '.env' and modify the values for your environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Project & System Environment Settings
# ------------------------------------------------------------------------------
PROJECT_NAME="StatementX AI Core Engine"
API_STR="/api"
ENVIRONMENT=production # set to "development" or "production"

# ------------------------------------------------------------------------------
# 2. Third-Party AI Engine API Tokens
# ------------------------------------------------------------------------------
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSy...your_gemini_key_here

# Get your Hugging Face user token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_...your_hugging_face_token_here

# ------------------------------------------------------------------------------
# 3. Production PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres_db_user
POSTGRES_PASSWORD=postgres_secure_password_replace_me
POSTGRES_DB=statementx
POSTGRES_PORT=5432

# Database Connection URL:
# Inside Docker, the database service is named 'db', so we connect to it using:
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ------------------------------------------------------------------------------
# 4. Domain & SSL/TLS Deployment Settings (AWS EC2 / Certbot)
# ------------------------------------------------------------------------------
# The fully qualified domain name pointing to your EC2 instance (e.g. statementx.mycompany.com)
DOMAIN_NAME=statementx.example.com

# Email address associated with SSL certificates (used by Certbot for renewal alerts)
SSL_EMAIL=devops@example.com
