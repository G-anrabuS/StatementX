# StatementX Environment Configurations Template
# Replace with your actual Gemini API Key from Google AI Studio
GEMINI_API_KEY=AIzaSy...

# Database Connection URL (PostgreSQL or SQLite)
# Example for local SQLite database (Default):
DATABASE_URL=sqlite:///./statementx.db

# Example for production PostgreSQL database:
# DATABASE_URL=postgresql://username:password@localhost:5432/statementx

# JWT Secret Key (Generate a long random string)
SECRET_KEY=yoursupersecretjwtkeyhere

# Google OAuth Client ID (From Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
